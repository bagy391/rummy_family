{
  "name": "@rummy/shared",
  "version": "0.1.0",
  "description": "Shared game engine for Family Rummy card game",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0",
    "rimraf": "^6.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "UNLICENSED",
  "private": true
}
